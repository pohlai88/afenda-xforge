{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./db": "./db.ts",
    "./drizzle.config": "./drizzle.config.ts",
    "./keys": "./keys.ts",
    "./seed": "./seed.ts",
    "./schema": "./schema.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "db.ts",
    "drizzle.config.ts",
    "index.ts",
    "keys.ts",
    "seed.ts",
    "schema.ts",
    "scripts",
    "package.json"
  ],
  "scripts": {
    "lint": "biome check db.ts drizzle.config.ts index.ts keys.ts seed.ts schema.ts scripts/block-db-push.mjs scripts/migrate-local.mjs scripts/validate-env.mjs",
    "format": "biome format --write db.ts drizzle.config.ts index.ts keys.ts seed.ts schema.ts scripts/block-db-push.mjs scripts/migrate-local.mjs scripts/validate-env.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate-local.mjs",
    "db:migrate:kit": "drizzle-kit migrate",
    "db:push": "node scripts/block-db-push.mjs",
    "db:seed": "tsx seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:validate-env": "node scripts/validate-env.mjs",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@repo/logger": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "server-only": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
