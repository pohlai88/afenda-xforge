{
  "name": "@repo/metadata-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./index.tsx",
    "./adapters": "./src/adapters/index.ts",
    "./components": "./src/components/index.ts",
    "./compatibility": "./src/compatibility/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./fixtures": "./src/fixtures.ts",
    "./policy": "./src/policy/index.ts",
    "./registry": "./src/registry/index.ts",
    "./renderers": "./src/renderers/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "architecture-and-feature-requirement.md",
    "README.md",
    "index.tsx",
    "metadata-ui.manifest.ts",
    "package.json",
    "src",
    "tests",
    "tsconfig.build.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check:boundaries": "tsx scripts/check-boundaries.mts",
    "check:change-note": "tsx scripts/check-change-note.mts",
    "check:compose-groups": "tsx scripts/check-compose-groups.mts",
    "check:consumer-fixture": "tsx scripts/check-consumer-fixture.mts && vitest run tests/public-api-consumer.render.test.tsx",
    "check:declaration-snapshot": "tsx scripts/check-declaration-snapshot.mts",
    "check:field-visual-tokens": "tsx scripts/check-field-visual-tokens.mts",
    "check:field-a11y": "tsx scripts/check-field-a11y.mts",
    "check:keyboard-focus": "tsx scripts/check-keyboard-focus.mts",
    "check:locale-formatting": "tsx scripts/check-locale-formatting.mts",
    "check:density-visual": "tsx scripts/check-density-visual.mts",
    "check:action-visual-states": "tsx scripts/check-action-visual-states.mts",
    "check:visual-states": "tsx scripts/check-visual-states.mts",
    "check:generated": "tsx scripts/generate.mts --check",
    "check:quality-score": "tsx scripts/check-quality-score.mts --threshold 90",
    "check:public-api": "tsx scripts/check-public-api.mts",
    "check:renderer-registry": "tsx scripts/check-compose-groups.mts",
    "check:telemetry-schema": "tsx scripts/check-telemetry-schema.mts",
    "generate": "tsx scripts/generate.mts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "tsx --test tests/index.test.ts",
    "test:render": "vitest run tests/public-api-consumer.render.test.tsx",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "update:declaration-snapshot": "tsx scripts/update-declaration-snapshot.mts",
    "verify": "pnpm run generate && pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run test && pnpm run check:boundaries && pnpm run check:public-api && pnpm run check:declaration-snapshot && pnpm run check:change-note && pnpm run check:telemetry-schema && pnpm run check:consumer-fixture && pnpm run check:generated && pnpm run check:compose-groups && pnpm run check:field-visual-tokens && pnpm run check:field-a11y && pnpm run check:keyboard-focus && pnpm run check:locale-formatting && pnpm run check:density-visual && pnpm run check:visual-states && pnpm run check:action-visual-states && pnpm run check:quality-score"
  },
  "dependencies": {
    "@repo/customization": "workspace:*",
    "@repo/metadata": "workspace:*",
    "@repo/ui": "workspace:*",
    "react": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react-dom": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
