{
  "name": "@repo/metadata-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./index.tsx",
    "./adapters": "./src/adapters/index.ts",
    "./components": "./src/components/index.ts",
    "./compatibility": "./src/compatibility/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./policy": "./src/policy/index.ts",
    "./registry": "./src/registry/index.ts",
    "./renderers": "./src/renderers/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "architecture.md",
    "README.md",
    "index.tsx",
    "package.json",
    "src",
    "tests",
    "tsconfig.build.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check:boundaries": "tsx scripts/check-boundaries.mts",
    "check:change-note": "tsx scripts/check-change-note.mts",
    "check:consumer-fixture": "vitest run tests/public-api-consumer.render.test.tsx",
    "check:declaration-snapshot": "tsx scripts/check-declaration-snapshot.mts",
    "check:public-api": "tsx scripts/check-public-api.mts",
    "check:telemetry-schema": "tsx scripts/check-telemetry-schema.mts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "tsx --test tests/index.test.ts",
    "test:render": "vitest run tests/public-api-consumer.render.test.tsx",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "update:declaration-snapshot": "tsx scripts/update-declaration-snapshot.mts",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run test && pnpm run check:boundaries && pnpm run check:public-api && pnpm run check:declaration-snapshot && pnpm run check:change-note && pnpm run check:telemetry-schema && pnpm run check:consumer-fixture"
  },
  "dependencies": {
    "@repo/customization": "workspace:*",
    "@repo/metadata": "workspace:*",
    "@repo/ui": "workspace:*",
    "react": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react-dom": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
