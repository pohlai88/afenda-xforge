    {
      "name": "metadata.section.render.error",
      "level": "error",
      "requiredContext": ["correlationId"],
      "allowsDiagnostics": true,
      "allowsGovernanceDecision": false,
      "attributes": ["sectionKey", "message"]
    },
    {
      "name": "metadata.section.render.started",
      "level": "debug",
      "requiredContext": ["correlationId"],
      "allowsDiagnostics": true,
      "allowsGovernanceDecision": true,
      "attributes": ["sectionKey", "sectionKind", "visible"]
    },
    {
      "name": "metadata.state.render.completed",
      "level": "info",
      "requiredContext": ["correlationId"],
      "allowsDiagnostics": true,
      "allowsGovernanceDecision": false,
      "attributes": ["state"]
    },
    {
      "name": "metadata.state.render.error",
      "level": "error",
      "requiredContext": ["correlationId"],
      "allowsDiagnostics": true,
      "allowsGovernanceDecision": false,
      "attributes": ["state", "message"]
    },
    {
      "name": "metadata.state.render.started",
      "level": "debug",
      "requiredContext": ["correlationId"],
      "allowsDiagnostics": true,
      "allowsGovernanceDecision": false,
      "attributes": ["state"]
    }
