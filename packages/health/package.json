{
  "name": "@repo/health",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./checks": "./checks.ts",
    "./manager": "./manager.ts",
    "./routes": "./routes.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "checks.ts",
    "index.ts",
    "manager.ts",
    "routes.ts",
    "package.json"
