{
  "name": "@repo/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./blob": "./blob/index.ts",
    "./blob/client": "./blob/client.ts",
    "./blob/keys": "./blob/keys.ts",
    "./provider": "./provider.ts",
    "./r2": "./r2/index.ts",
    "./r2/keys": "./r2/keys.ts",
    "./types": "./types.ts",
    "./supabase": "./supabase/index.ts",
    "./supabase/keys": "./supabase/keys.ts",
    "./package.json": "./package.json"
  },
  "files": [
    ".env.example",
    "blob",
    "index.ts",
    "provider.ts",
    "r2",
    "supabase",
    "types.ts",
    "package.json"
  ],
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "@vercel/blob": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "server-only": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*"
  }
}
