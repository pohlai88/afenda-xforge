# Default north-star provider is Postgres FTS (`postgres`). Use `meilisearch` for legacy Meilisearch.
SEARCH_PROVIDER=postgres
SEARCH_POSTGRES_WRITE_ADAPTER=neon
SEARCH_POSTGRES_READ_ADAPTER=neon
# Optional Supabase PostgREST read adapter (materialized read API).
SEARCH_POSTGREST_URL=
SEARCH_POSTGREST_KEY=

MEILISEARCH_URL=
MEILISEARCH_API_KEY=
# Required when running `pnpm --filter @repo/search test:integration` directly.
MEILISEARCH_INTEGRATION=false
MEILISEARCH_INDEX_PREFIX=xforge
MEILISEARCH_TIMEOUT_MS=30000
MEILISEARCH_DEFAULT_LIMIT=20
