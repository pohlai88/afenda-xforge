{
  "name": "@repo/search",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./language": "./language.ts",
    "./registry": "./registry.ts",
    "./types": "./types.ts",
    "./meilisearch": "./meilisearch/index.ts",
    "./meilisearch/client": "./meilisearch/client.ts",
    "./meilisearch/indexer": "./meilisearch/indexer.ts",
    "./meilisearch/keys": "./meilisearch/keys.ts",
    "./meilisearch/search": "./meilisearch/search.ts",
    "./postgres": "./postgres/index.ts",
    "./postgres/keys": "./postgres/keys.ts",
    "./postgres/neon": "./postgres/neon/index.ts",
    "./postgres/postgrest": "./postgres/postgrest/index.ts",
    "./postgres/internal": "./postgres/internal.ts",
    "./package.json": "./package.json"
  },
  "files": [
    ".env.example",
    "index.ts",
    "language.ts",
    "registry.ts",
    "types.ts",
    "meilisearch",
    "postgres",
    "package.json"
  ],
  "scripts": {
    "build": "pnpm run typecheck",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "pnpm exec vitest run",
    "test:integration": "pnpm exec vitest run tests/meilisearch.integration.test.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@repo/database": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "drizzle-orm": "catalog:",
    "meilisearch": "catalog:",
    "server-only": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:",
    "typescript": "catalog:"
  }
}
