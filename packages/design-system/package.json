{
  "name": "@repo/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/*": "./src/contracts/*.ts",
    "./tokens": "./src/tokens/index.ts",
    "./tokens/*": "./src/tokens/*.ts",
    "./variants": "./src/variants/index.ts",
    "./variants/*": "./src/variants/*.ts"
  },
  "files": [
    "architecture.md",
    "README.md",
    "src",
    "package.json",
    "tsconfig.build.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "type2:css": "tsx scripts/generate-type2-css.mts",
    "type2:css:check": "tsx scripts/generate-type2-css.mts --check",
    "type2:css:compare": "tsx scripts/generate-type2-css.mts --compare",
    "test": "node --import tsx --test src/tests/design-system.test.ts src/tests/token-contract.test.ts src/tests/type2-css.test.ts src/tests/variant-contract.test.ts src/tests/public-exports.test.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
