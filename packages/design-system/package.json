{
  "name": "@repo/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/*": "./src/contracts/*.ts",
    "./tokens": "./src/tokens/index.ts",
    "./tokens/*": "./src/tokens/*.ts",
    "./variants": "./src/variants/index.ts",
    "./variants/*": "./src/variants/*.ts",
    "./resolution": "./src/resolution/index.ts",
    "./tenant-branding": "./src/tenant-branding/in-memory-store.ts"
  },
  "files": [
    "architecture-and-feature-requirement.md",
    "README.md",
    "src",
    "package.json",
    "tsconfig.build.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "globals:css": "tsx scripts/generate-globals-css.mts",
    "globals:css:check": "tsx scripts/generate-globals-css.mts --check",
    "check:hue-reservation": "tsx scripts/check-hue-reservation.mts",
    "check:color-contrast": "tsx scripts/check-color-contrast.mts",
    "test": "node --import tsx --test src/tests/design-system.test.ts src/tests/token-contract.test.ts src/tests/globals-css.test.ts src/tests/variant-contract.test.ts src/tests/public-exports.test.ts src/tests/resolve-tenant-branding.test.ts src/tests/merge-effective-branding.test.ts src/tests/hue-reservation.test.ts src/tests/validate-branding-colors.test.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "culori": "^4.0.2",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
