{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "**/.env",
    "**/.env.*",
    "**/.env.*local",
    "AGENTS.md",
    "biome.jsonc",
    "docs/runtime/**/*.md",
    "package.json",
    "pnpm-workspace.yaml",
    "skills/reference/**/*.md",
    "tsconfig.base.json",
    "packages/typescript-config/**/*.json",
    "tools/check-architecture-boundaries.mjs",
    "tools/check-ui-package-boundaries.mjs",
    "tools/scaffold-hr-suite-features.mjs",
    "turbo/generators/**/*"
  ],
  "envMode": "strict",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "test"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "storybook-static/**",
        "coverage/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": []
    }
  }
}
