{
  "name": "xforge",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "zod": "4.3.6"
    }
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "env:consolidate": "node scripts/sync-env.mjs consolidate",
    "env:doctor": "node scripts/sync-env.mjs doctor",
    "env:sync": "node scripts/sync-env.mjs sync",
    "webhooks:local:api": "node scripts/webhooks-local.mjs api",
    "webhooks:local:bootstrap": "node scripts/webhooks-local.mjs bootstrap",
    "webhooks:local:doctor": "node scripts/webhooks-local.mjs doctor",
    "webhooks:integration": "node scripts/webhooks-local.mjs integration",
    "webhooks:local:smoke": "node scripts/webhooks-local.mjs smoke",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "ci": "turbo build lint typecheck --affected && pnpm --filter @repo/generators build && pnpm run ci:metadata-ui",
    "ci:full": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm --filter @repo/generators build && pnpm run ci:metadata-ui",
    "ci:metadata-ui": "pnpm --filter @repo/metadata-ui verify && pnpm --filter app check:metadata-ui-smoke",
    "gen": "turbo gen package",
    "gen:app": "turbo gen app",
    "gen:feature": "turbo gen feature",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:deps": "knip --production --dependencies",
    "lint": "pnpm lint:doctor && pnpm lint:biome && pnpm lint:architecture && pnpm lint:ui-boundaries",
    "lint:architecture": "node tools/check-architecture-boundaries.mjs",
    "lint:ui-boundaries": "node tools/check-ui-package-boundaries.mjs",
    "lint:biome": "biome check .",
    "lint:biome:ci": "biome ci .",
    "lint:doctor": "ultracite doctor",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "clean": "turbo clean",
    "clean:hard": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@turbo/gen": "catalog:",
    "@types/node": "catalog:",
    "knip": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "ultracite": "catalog:"
  }
}
