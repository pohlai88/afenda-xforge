{
  "name": "storybook",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 6006",
    "dev:clean": "node -e \"require('node:fs').rmSync('.cache',{recursive:true,force:true}); require('node:fs').rmSync('node_modules/.cache/storybook',{recursive:true,force:true})\" && storybook dev -p 6006",
    "build": "storybook build",
    "build:pages": "storybook build",
    "check": "pnpm run typecheck && pnpm run check:theme-css && pnpm run check:stylelint && pnpm run check:intro-layout && pnpm run check:storybook-visual-tokens && pnpm run check:hardcoded-css && pnpm run check:build",
    "check:theme-css": "tsx scripts/check-theme-css.mts",
    "check:stylelint": "pnpm --dir ../.. run lint:stylelint",
    "check:intro-layout": "tsx scripts/check-intro-layout.mts",
    "check:storybook-visual-tokens": "tsx scripts/check-storybook-visual-tokens.mts",
    "check:hardcoded-css": "tsx scripts/check-hardcoded-css.mts",
    "check:hardcoded-css:self-test": "tsx scripts/check-hardcoded-css.mts --self-test",
    "check:build": "storybook build --quiet",
    "check:metadata-ui-browser-smoke": "pnpm run pretest:browser && tsx scripts/check-metadata-ui-browser-smoke.mts",
    "audit:a11y": "tsx scripts/audit-story-a11y.mts",
    "scorecard": "tsx scripts/storybook-scorecard.mts",
    "generate:compose-stories": "tsx scripts/generate-compose-stories.mts",
    "pretest:browser": "playwright install chromium",
    "pretest:stories": "pnpm --filter @repo/metadata-ui check:generated && pnpm run pretest:browser",
    "preview:static": "npx --yes http-server storybook-static -p 6007",
    "test:stories": "pnpm run pretest:stories && tsx scripts/run-storybook-tests.mts",
    "test:visual": "pnpm run pretest:browser && tsx tests/visual/golden-stories.spec.mts",
    "test:visual:intro": "pnpm run pretest:browser && tsx tests/visual/golden-stories.spec.mts --intro",
    "test:visual:update": "pnpm run pretest:browser && tsx tests/visual/golden-stories.spec.mts --update",
    "test:visual:intro:update": "pnpm run pretest:browser && tsx tests/visual/golden-stories.spec.mts --intro --update",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@repo/design-system": "workspace:*",
    "@repo/features-employee-management-documents-management": "workspace:*",
    "@repo/features-system-admin-control-plane": "workspace:*",
    "@repo/metadata": "workspace:*",
    "@repo/metadata-ui": "workspace:*",
    "@repo/ui": "workspace:*",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "next-intl": "catalog:",
    "storybook": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/test-runner": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "axe-playwright": "catalog:",
    "playwright": "1.60.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
